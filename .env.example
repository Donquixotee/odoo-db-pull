# ── App ───────────────────────────────────────────────────────────────────────
APP_PORT=8100

# ── Local PostgreSQL ──────────────────────────────────────────────────────────
# Unix socket directory for local postgres (peer auth)
POSTGRES_SOCKET_PATH=/var/run/postgresql

# Postgres user for createdb / pg_restore (defaults to $USER if unset)
PGUSER=

# ── Paths ─────────────────────────────────────────────────────────────────────
# Path to your SSH config directory (contains config + private keys)
SSH_CONFIG_PATH=~/.ssh

# Local Odoo filestore root — rsync destination
LOCAL_FILESTORE_PATH=~/.local/share/Odoo/filestore